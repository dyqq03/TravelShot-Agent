# TravelShot Agent local demo configuration

# App
APP_ENV=development
API_PORT=8000
WEB_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_ACCESS_TOKEN=
NEXT_PUBLIC_API_ACCESS_TOKEN=
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
API_RATE_LIMIT_PER_MINUTE=60

# Runtime services
POSTGRES_DB=travelshot
POSTGRES_USER=travelshot
POSTGRES_PASSWORD=travelshot_dev_password
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://travelshot:travelshot_dev_password@localhost:5433/travelshot
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0
REQUIRE_RUNTIME_SERVICES=true
RUNTIME_CHECK_TIMEOUT_SECONDS=0.75

# LLM
LLM_API_KEY=your_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_DELAY_SECONDS=1.5
LLM_MAX_TOKENS=6144

# Vision model for reference images. Leave empty to skip image understanding.
VISION_API_KEY=
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen-vl-plus
VISION_TIMEOUT_SECONDS=60
VISION_MAX_TOKENS=4096

# Agent controls
AGENT_MAX_LLM_CALLS=7
AGENT_MAX_TOOL_ROUNDS=4
AGENT_MAX_TOOL_REQUESTS_PER_BATCH=10
AGENT_MAX_ROUTE_REQUESTS=4
AGENT_ROUTE_TOOLS_MAX_DATES=3
PLAN_CACHE_TTL_SECONDS=86400
HISTORY_RETENTION_DAYS=7

# Tools
SPOT_DATA_DIR=db/seed/spots
IMPORT_SEED_SPOTS_ON_STARTUP=true
OPEN_METEO_BASE_URL=https://api.open-meteo.com
WEATHER_TIMEOUT_SECONDS=5
TOOL_CACHE_TTL_SECONDS=1800
AMAP_API_KEY=
AMAP_BASE_URL=https://restapi.amap.com
AMAP_TIMEOUT_SECONDS=5
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_TIMEOUT_SECONDS=8
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_EMAIL=
